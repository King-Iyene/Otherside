# ---- Required ----
# Notion internal integration token (starts with "ntn_" or "secret_").
# Create at https://www.notion.so/profile/integrations and connect it to the
# four databases (see README step 2).
NOTION_TOKEN=

# ---- Optional ----
# Set a password to lock the dashboard. Leave empty for open access.
DASHBOARD_PASSWORD=

# Challenge Master Cash Tracker (Google Sheet).
# The ID is the long string in the sheet URL between /d/ and /edit.
CHALLENGE_SHEET_ID=1mJ3DLye8otnjs2CbUganWGNQbciBssZFHEFusoGQFpc
# gid of the specific tab (in the URL after #gid=). 0 = first tab.
CHALLENGE_SHEET_GID=0
