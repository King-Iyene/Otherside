# Notion internal integration token (workspace-scoped fallback, server-side only).
# Leave empty if you're using OAuth (see below) — each user connects their own account.
NOTION_TOKEN=

# Notion OAuth "Public integration" credentials — enables the in-app "Connect
# my Notion account" button so members without admin access can use their own
# Notion permissions instead of relying on NOTION_TOKEN. Both blocks can coexist:
# OAuth wins per-user, NOTION_TOKEN is the fallback.
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
# Optional. If unset, the callback URL is derived from the current request host
# (works out of the box on Vercel preview + production).
NOTION_OAUTH_REDIRECT_URI=

# Optional password gate. Leave unset to disable the login wall entirely.
DASHBOARD_PASSWORD=

# Challenge Master Cash Tracker Google Sheet
CHALLENGE_SHEET_ID=1mJ3DLye8otnjs2CbUganWGNQbciBssZFHEFusoGQFpc
CHALLENGE_SHEET_GID=0

# Monthly business targets — power the Overview hero-row pace bars.
# Change any of these + redeploy; no code changes.
TARGET_MONTHLY_CASH=150000
TARGET_MONTHLY_REVENUE=200000
TARGET_MONTHLY_ENROLLMENTS=40

# Stripe reconciliation (server-side only, READ-ONLY).
# Should be a RESTRICTED KEY (rk_live_... / rk_test_...) with Read-only
# permissions on: Charges, Refunds, Customers, PaymentIntents.
# NOT a Secret Key (sk_live_...) — that has full write access.
# When set, the "Reconciliation" tab lights up.
STRIPE_SECRET_KEY=

# Per-closer benchmarks (used on scorecards + coaching flags). All optional;
# defaults are calibrated for high-ticket coaching sales.
BENCHMARK_SHOW_PCT=0.60
BENCHMARK_OFFER_PCT=0.70
BENCHMARK_CLOSE_PCT_SHOWS=0.20
BENCHMARK_CLOSE_PCT_OFFERS=0.28
BENCHMARK_DAILY_CALLS=8
BENCHMARK_WEEKLY_CASH_ON_CALL=15000
BENCHMARK_AVG_DEAL_SIZE=3000
